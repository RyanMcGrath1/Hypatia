EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# News service (top headlines home tab). Native apps use this host; Expo Web **dev** ignores loopback URLs here
# and uses the same-origin Metro proxy in metro.config.js (avoids CORS). Use a LAN/public URL when you need the
# client to hit a non-loopback API from web dev (then enable CORS on that server).
EXPO_PUBLIC_NEWS_API_BASE_URL=http://127.0.0.1:5001

# Backend-only secrets should stay out of this Expo app.
# Keep them in your Flask/backend .env (not committed), for example:
# THIRD_PARTY_API_KEY=replace-me
